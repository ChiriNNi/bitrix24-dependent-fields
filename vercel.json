{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/app"
    },
    {
      "source": "/index.html",
      "destination": "/api/app"
    },
    {
      "source": "/install.html",
      "destination": "/api/install"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://tootopbrass.bitrix24.kz https://*.bitrix24.kz https://*.bitrix24.com https://*.bitrix24.ru"
        }
      ]
    }
  ]
}
